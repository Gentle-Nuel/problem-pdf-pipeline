# Same Supabase project as the main pipeline repo — build-time only, never
# shipped to the browser (this is a fully static site). Set these in this
# site's own Vercel project env vars (a separate project from the main
# pipeline, even though it lives in the same repo — see README step 8b).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# This site's own stable production URL (a *.vercel.app URL is fine) —
# needed for sitemap.xml, canonical tags, and robots.txt to generate
# correct absolute URLs. You won't know this until after the first
# deploy — set it then and redeploy once.
PUBLIC_SITE_URL=
