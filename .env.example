# Supabase (Settings -> API in your Supabase project)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Voyage AI (embeddings for clustering — step 3)
VOYAGE_API_KEY=

# Gemini (research step — step 5). Anthropic was the original plan but
# requires a paid credit purchase up front; Gemini's free tier via
# aistudio.google.com needs no payment method. Get a key there. Swap back
# to Claude later by pointing lib/researchClusters.ts at lib/claude.ts's
# researchProblem instead (git history has the original implementation).
GEMINI_API_KEY=

# Telegram bot (approval / review taps — step 4+). Create the bot via
# @BotFather for the token; TELEGRAM_CHAT_ID is your own chat id (see
# README step 4 for how to find it). TELEGRAM_WEBHOOK_SECRET is any random
# string — Telegram echoes it back on every webhook call so
# api/telegram-webhook.ts can verify requests actually came from Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Stack Exchange API (scraper — step 2). No auth required to read public
# questions; this key just raises the shared per-IP quota from 300/day to
# 10,000/day. Register at stackapps.com/apps/oauth/register. Optional.
STACKEXCHANGE_KEY=

# Random secret string — set the same value in Vercel's env vars and in the
# Authorization header Vercel Cron sends, so /api/scrape-stackexchange can't
# be triggered by anyone who finds the URL. Optional but recommended.
CRON_SECRET=

# Gumroad (publish step — step 9)
GUMROAD_ACCESS_TOKEN=
