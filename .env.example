# Supabase (Settings -> API in your Supabase project)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Voyage AI (embeddings for clustering — step 3)
VOYAGE_API_KEY=

# Gemini (research step — step 5). Anthropic was the original plan but
# requires a paid credit purchase up front; Gemini's free tier via
# aistudio.google.com needs no payment method. Get a key there. Swap back
# to Claude later by pointing lib/researchClusters.ts at lib/claude.ts's
# researchProblem instead (git history has the original implementation).
GEMINI_API_KEY=

# Tavily (real web search for the research step — Gemini's own search
# grounding is billing-gated, so we search ourselves and hand Gemini real
# results). Free tier: 1,000 searches/month, no card required. Sign up at
# tavily.com.
TAVILY_API_KEY=

# Telegram bot (approval / review taps — step 4+). Create the bot via
# @BotFather for the token; TELEGRAM_CHAT_ID is your own chat id (see
# README step 4 for how to find it). TELEGRAM_WEBHOOK_SECRET is any random
# string — Telegram echoes it back on every webhook call so
# api/telegram-webhook.ts can verify requests actually came from Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Stack Exchange API (scraper — step 2). No auth required to read public
# questions; this key just raises the shared per-IP quota from 300/day to
# 10,000/day. Register at stackapps.com/apps/oauth/register. Optional.
STACKEXCHANGE_KEY=

# Random secret string — set the same value in Vercel's env vars and in the
# Authorization header Vercel Cron sends, so /api/scrape-stackexchange can't
# be triggered by anyone who finds the URL. Optional but recommended.
CRON_SECRET=

# Static blog site deploy trigger (step 8b). VERCEL_DEPLOY_HOOK_URL comes
# from the site's own Vercel project (Settings -> Git -> Deploy Hooks) once
# it exists — see README step 8b. PUBLIC_SITE_URL is that project's stable
# production URL (a *.vercel.app URL is fine), used to build published_url
# per post. Both optional — lib/publishBlogPosts.ts no-ops quietly until
# both are set, so nothing breaks before the site exists.
VERCEL_DEPLOY_HOOK_URL=
PUBLIC_SITE_URL=

# Gumroad. NOT needed for step 9 as actually built — verified live that
# Gumroad's API can't create a product with a file at all, so step 9 is a
# manual-listing handoff via Telegram, no token required. Worth generating
# later (Settings -> Advanced -> Applications on gumroad.com) for what the
# API does support: toggling an existing listing live/hidden, and pulling
# sales data back into cluster scoring (see docs/spec.md "Pricing
# strategy") — not built yet, no code currently reads this var.
GUMROAD_ACCESS_TOKEN=
